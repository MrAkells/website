---
import '../styles/global.css';

type Props = {
	title: string;
	description?: string;
};

const { title, description } = Astro.props;
const { pathname } = Astro.url;

const navItems = [
	{ label: 'Home', href: '/', active: pathname === '/' },
	{ label: 'Blog', href: '/blog/', active: pathname.startsWith('/blog') },
	{ label: 'Minecraft', href: '/minecraft/', active: pathname.startsWith('/minecraft') },
];
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
	</head>
	<body class="min-h-screen bg-[var(--color-bg)] font-mono text-[var(--color-text)]">
		<header class="border-b border-[var(--color-border)] bg-[var(--color-header-bg)]">
			<div class="mx-auto flex h-16 w-full max-w-5xl items-center justify-between px-6">
				<a href="/" aria-label="Home">
					<img class="size-8 rounded-sm" src="/favicon.png" alt="" />
				</a>

				<nav class="flex gap-6 text-sm text-[var(--color-text-muted)]">
					{
						navItems.map((item) => (
							<a
								class:list={[
									'hover:text-[var(--color-text)]',
									item.active && 'text-[var(--color-accent)]',
								]}
								href={item.href}
								aria-current={item.active ? 'page' : undefined}
							>
								{item.label}
							</a>
						))
					}
				</nav>
			</div>
		</header>

		<main class="mx-auto w-full max-w-5xl px-6 py-8">
			<div class="space-y-7">
				<slot name="header" />
				<slot />
			</div>
		</main>
	</body>
</html>
