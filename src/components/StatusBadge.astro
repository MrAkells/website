---
type Props = {
	label?: string;
};

const { label = 'Online' } = Astro.props;
---

<span class="inline-flex items-center gap-2 rounded-sm bg-[var(--color-surface-muted)] px-3 py-1 text-sm text-[var(--color-success)] outline outline-1 outline-[var(--color-border)]">
	<span class="size-2 rounded-full bg-[var(--color-success)]"></span>
	{label}
</span>
